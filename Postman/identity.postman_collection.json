              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response indeholder accessToken\", function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.accessToken).to.be.a(\"string\").and.not.empty;",
              "});"
